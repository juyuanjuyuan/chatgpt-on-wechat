POSTGRES_DB=cowagent
POSTGRES_USER=cow
POSTGRES_PASSWORD=cow
POSTGRES_URL=postgresql+psycopg2://cow:cow@postgres:5432/cowagent
JWT_SECRET=cowagent-jwt
MEDIA_TOKEN=media-secret
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASS=admin123
MCP_BASE_URL=http://mcp-api-server:8001
PROMPT_CACHE_SECONDS=30
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:8001
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# Auto followup scheduler
FOLLOWUP_ENABLED=false
FOLLOWUP_INTERVAL_SECONDS=3600
FOLLOWUP_MIN_IDLE_HOURS=2
FOLLOWUP_MAX_ATTEMPTS=3

# Candidate profile extraction
PROFILE_EXTRACTION_ENABLED=true
PROFILE_EXTRACTION_INTERVAL_SECONDS=300
PROFILE_EXTRACTION_IDLE_MINUTES=20
PROFILE_EXTRACTION_BATCH_LIMIT=50
PROFILE_EXTRACTION_CHANNELS=wechatcom_app,wework
PROFILE_EXTRACTION_MODEL=gpt-3.5-turbo
PROFILE_EXTRACTION_TEMPERATURE=0.1
PROFILE_EXTRACTION_MAX_TOKENS=220
